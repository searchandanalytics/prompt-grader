# PromptGrade backend environment — copy to .env and fill in what you have.
# All keys are OPTIONAL. The app works without any API key (rule-based mode).
# Recommended free default: install Ollama (https://ollama.com) and pull llama3.1:8b

# --- LLM Provider Keys (pick one or more; first found wins) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=gsk_...

# --- Ollama (local, free) ---
# OLLAMA_BASE_URL=http://localhost:11434   # default; uncomment to override

# --- Judge selection (auto-detected if not set) ---
# JUDGE_PROVIDER=anthropic|openai|google|groq|ollama
# JUDGE_MODEL=claude-sonnet-4-6

# --- Hybrid grader weights (must sum to 1.0) ---
# RULES_WEIGHT=0.3
# LLM_WEIGHT=0.7

# --- App ---
# DATABASE_URL=sqlite+aiosqlite:///./promptgrade.db
# LOG_LEVEL=INFO
